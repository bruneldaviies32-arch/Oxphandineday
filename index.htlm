      font-size: 1.4rem;
      font-weight: bold;
      font-family: 'Times New Roman', Times, serif;
      background: transparent;
      color: #fff;
      border: 2px solid #fff;
      cursor: pointer;
      z-index: 10;
      transition: all 0.3s ease;
    }
