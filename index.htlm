      color: #000;
    }

    /* --- ÉCRAN FINAL AVEC TEXTE DÉFILANT (image1.png) --- */
    #final-screen {
      display: none;
      width: 100%;
      height: 100%;
      background: url('actifs/Image/image1.png') no-repeat center center;
      background-size: cover;
      position: relative;
    }
    #story-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.4); /* Filtre sombre pour garantir la lisibilité du texte blanc */
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px;
      text-align: center;
    }
    #story-text {
      font-size: 2.2rem;
      font-weight: bold;
      line-height: 1.6;
      max-width: 800px;
      color: #fff;
      text-shadow: 0px 2px 10px rgba(0,0,0,0.8);
      opacity: 0;
      transition: opacity 1s ease-in-out; /* Effet fondu entre les phrases */
    }

    .hidden { display: none !important; }
